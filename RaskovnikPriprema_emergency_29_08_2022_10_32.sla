        <MASTEROBJECT XPOS="139.685039370079" YPOS="582.918918918919" OwnPage="2" ItemID="482289445" PTYPE="4" WIDTH="515.905511811024" HEIGHT="19.8918918918919" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 19.8919 L0 19.8919 L0 0 Z" copath="M0 0 L515.906 0 L515.906 19.8919 L0 19.8919 L0 0 Z" OnMasterPage="New Master Page 2" gXpos="4108731.81102316" gYpos="80970268.5882102" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
